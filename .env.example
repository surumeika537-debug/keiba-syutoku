# keiba-syutoku environment variables.
#
# 使い方:
#   cp .env.example .env
#   # 値を埋める
#   # .env は .gitignore で除外される — 絶対に git commit しない
#
# python-dotenv で auto load される (src/notifications.py 経由)。

# ---- Telegram 通知 ------------------------------------------------------
# BotFather でBot作成 → /newbot → token を貼る
TELEGRAM_BOT_TOKEN=
# /start を bot に送ってから
# https://api.telegram.org/bot<TOKEN>/getUpdates の "chat":{"id":<数字>} を貼る
TELEGRAM_CHAT_ID=
# 'true' で実送信、それ以外なら全 skip (CI / dev 用 kill switch)
ENABLE_TELEGRAM=false

# ---- スクレイプ設定 (上書きしたい場合のみ) ------------------------------
# FETCH_SLEEP_SECONDS=3.0
# FETCH_TIMEOUT_SECONDS=20.0
# FETCH_USER_AGENT=keiba-trifecta-analysis/0.1 (contact: you@example.com)
# KEIBA_SOURCE=netkeiba
